{
  "name": "pc-spec-poster-desktop",
  "version": "1.0.0",
  "description": "Desktop app for generating PC/Laptop spec posters in English and French",
  "main": "main.js",
  "scripts": {
    "start": "set ELECTRON_RUN_AS_NODE=&& electron --no-sandbox .",
    "dev": "set ELECTRON_RUN_AS_NODE=&& electron --no-sandbox .",
    "check": "node --check main.js && node --check renderer.js"
  },
  "devDependencies": {
    "electron": "^31.7.7",
    "nodemon": "^3.1.14"
  }
}
